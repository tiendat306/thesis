// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUM
//////////////////////

enum RoleName {
  OWNER
  STAFF
  CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  COD
  MOMO
  // BANKING
  // CRYPTO
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  LOGIN_FAILED
}

//////////////////////
// RBAC
//////////////////////

model Role {
  id   String   @id @default(uuid()) @db.Uuid
  name RoleName @unique

  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("roles")
}

model Permission {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

//////////////////////
// USER
//////////////////////

model User {
  id       String  @id @default(uuid()) @db.Uuid
  email    String  @unique
  password String
  fullName String  @map("full_name")
  phone    String?
  avatar   String?

  roleId   String  @map("role_id") @db.Uuid
  role     Role    @relation(fields: [roleId], references: [id])
  isActive Boolean @default(true) @map("is_active")

  addresses     Address[]
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  auditLogs AuditLog[]

  @@map("users")
}

//////////////////////
// ADDRESS
//////////////////////

model Address {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  fullName String @map("full_name")
  phone    String

  street   String
  ward     String
  district String
  city     String

  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

//////////////////////
// PRODUCT
//////////////////////

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  slug        String  @unique
  description String?
  image       String?
  publicId    String?    @map("public_id")
  parentId String?    @map("parent_id") @db.Uuid
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  isActive Boolean    @default(true) @map("is_active")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Brand {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  slug        String  @unique
  logo        String?
  publicId    String?    @map("public_id")
  description String?

  products Product[]

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("brands")
}

model Product {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  slug        String        @unique
  description String?
  brandId     String        @map("brand_id") @db.Uuid
  categoryId  String        @map("category_id") @db.Uuid
  basePrice   Int           @map("base_price") // Hiển thị "Từ xxx VNĐ"
  status      ProductStatus @default(DRAFT)
  isFeatured  Boolean       @default(false) @map("is_featured")
  totalSold   Int           @default(0) @map("total_sold")
  avgRating   Float         @default(0) @map("avg_rating")

  brand    Brand    @relation(fields: [brandId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  colors        ProductColor[]
  variants      ProductVariant[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([brandId])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
  @@map("products")
}

model ProductColor {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid

  name      String // e.g. "University Red", "Triple White"
  colorCode String? @map("color_code") // hex e.g. "#FF0000" cho color swatch trên UI

  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variants ProductVariant[]
  images   ProductImage[]

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([productId, name])
  @@index([productId])
  @@map("product_colors")
}

model ProductVariant {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  colorId   String @map("color_id") @db.Uuid

  size           String
  sku            String @unique // e.g. "NK-AF1-WHT-42"
  price          Int // giá bán thực tế
  compareAtPrice Int?   @map("compare_at_price") // giá gốc trước sale (hiển thị gạch ngang)
  stock          Int    @default(0)

  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  color      ProductColor @relation(fields: [colorId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([colorId, size])
  @@index([productId])
  @@index([colorId])
  @@map("product_variants")
}

model ProductImage {
  id      String @id @default(uuid()) @db.Uuid
  colorId String @map("color_id") @db.Uuid

  url String
  publicId String? @map("public_id")
  alt String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  color ProductColor @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@index([colorId])
  @@map("product_images")
}

//////////////////////
// SHOPPING
//////////////////////

model Cart {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String? @unique @map("user_id") @db.Uuid // Có thể null với Guest
  sessionId String? @unique @map("session_id") // Dùng cho Guest (lưu cookie)

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid()) @db.Uuid
  cartId    String @map("cart_id") @db.Uuid
  variantId String @map("variant_id") @db.Uuid
  quantity  Int    @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

//////////////////////
// ORDER
//////////////////////

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  orderNumber String      @unique @map("order_number")
  status      OrderStatus @default(PENDING)
  subtotal    Int
  shippingFee Int         @default(0) @map("shipping_fee")
  discount    Int         @default(0)
  total       Int
  note        String?

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  items           OrderItem[]
  payment         Payment[]
  shippingAddress OrderAddress?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderAddress {
  id      String @id @default(uuid()) @db.Uuid
  orderId String @unique @map("order_id") @db.Uuid

  fullName String @map("full_name")
  phone    String
  street   String
  ward     String
  district String
  city     String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("order_addresses")
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  variantId   String? @map("variant_id") @db.Uuid
  productName String  @map("product_name") // snapshot at time of order
  color       String
  size        String
  quantity    Int
  price       Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  review  Review?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_items")
}

//////////////////////
// PAYMENT
//////////////////////

model Payment {
  id      String @id @default(uuid()) @db.Uuid
  orderId String @map("order_id") @db.Uuid

  method PaymentMethod
  status PaymentStatus

  amount Int // Số tiền thực tế giao dịch qua cổng

  transactionId String? @unique @map("transaction_id")

  paidAt    DateTime? @map("paid_at") // Thời điểm chuyển status sang SUCCESS
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

//////////////////////
// REVIEW
//////////////////////

model Review {
  id          String  @id @default(uuid()) @db.Uuid
  userId      String  @map("user_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  orderItemId String? @unique @map("order_item_id") @db.Uuid // có giá trị = verified purchase

  rating     Int
  comment    String?
  isApproved Boolean @default(false) @map("is_approved")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@map("reviews")
}

//////////////////////
// AUDIT LOG
//////////////////////

model AuditLog {
  id     String  @id @default(uuid()) @db.Uuid
  userId String? @map("user_id") @db.Uuid // Người thực hiện hành động (có thể null nếu là System cronjob)

  action   ActionType
  entity   String // Tên bảng (VD: "ProductVariant", "Order", "User")
  entityId String     @map("entity_id") @db.Uuid // ID của record bị tác động

  oldValues Json? @map("old_values") // Dữ liệu trước khi sửa (Lưu JSON)
  newValues Json? @map("new_values") // Dữ liệu sau khi sửa (Lưu JSON)

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
